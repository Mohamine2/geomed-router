<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pgl.app.controller.SidebarController"
            prefHeight="700.0"
            prefWidth="250.0"
            style="-fx-background-color: #f1f5f9;">

    <children>
        <VBox spacing="12.0"
              prefWidth="250.0"
              prefHeight="700.0"
              style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-width: 0 0 0 1;">
            <padding>
                <Insets top="20.0" right="16.0" bottom="20.0" left="16.0"/>
            </padding>

            <children>
                <Label text="Controls"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <Separator />

                <Button text="Add Site"
                        maxWidth="Infinity"
                        onAction="#handleAddSite" />

                <Button text="Add User Point"
                        maxWidth="Infinity"
                        onAction="#handleAddUserPoint" />

                <Button text="Recompute Delaunay"
                        maxWidth="Infinity"
                        onAction="#handleRecompute" />

                <Button text="Clear"
                        maxWidth="Infinity"
                        onAction="#handleClear" />

                <Separator />
                <Separator />

				<Label text="Map statistics"
       			style="-fx-font-size: 16px; -fx-font-weight: bold;" />

				<Label fx:id="hospitalCountLabel"
       			text="Hospitals: 0" />

				<Label fx:id="incidentCountLabel"
       			text="Incidents: 0" />

				<Label fx:id="triangleCountLabel"
       			text="Triangles: 0" />

				<Separator />

				<Label fx:id="infoLabel"
       			text="No action yet."
       			wrapText="true"
       			style="-fx-font-size: 13px;" />
       			
       			<Label text="Last assignment"
       			style="-fx-font-size: 16px; -fx-font-weight: bold;" />

				<Label fx:id="lastIncidentLabel"
       			text="Last incident: none" />

				<Label fx:id="assignedHospitalLabel"
       			text="Assigned hospital: none" />

                <Label fx:id="infoLabel"
                       text="No action yet."
                       wrapText="true"
                       style="-fx-font-size: 13px;" />
            </children>
        </VBox>
    </children>
</AnchorPane>