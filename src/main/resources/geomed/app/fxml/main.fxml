<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="600.0" minWidth="900.0"
            prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="geomed.app.controller.MainController">

    <center>
        <SplitPane dividerPositions="0.75"
                   prefHeight="700.0"
                   prefWidth="1000.0"
                   BorderPane.alignment="CENTER">

            <items>
                <!-- Left zone: container for map.fxml -->
                <AnchorPane fx:id="mapContainer"
                            minHeight="0.0"
                            minWidth="400.0"
                            prefHeight="700.0"
                            prefWidth="750.0" />

                <!-- Right zone: container for sidebar.fxml -->
                <AnchorPane fx:id="sidebarContainer"
                            minHeight="0.0"
                            minWidth="220.0"
                            prefHeight="700.0"
                            prefWidth="250.0" />
            </items>

        </SplitPane>
    </center>
</BorderPane>